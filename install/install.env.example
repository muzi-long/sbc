# 拷为 install/install.env,填好变量后:
#   set -a; source install/install.env; set +a
#   sudo -E ./install/install.sh install

# ===== 网络(kamailio + rtpengine 必填) =====
PUBLIC_IP=""
PRIVATE_IP=""
LISTEN_IFACE="eth0"

# ===== kamailio SIP 监听(kamailio 必填) =====
SIP_UDP_PORT="15060"
SIP_TCP_PORT="15062"
KAM_ALIAS_1="soft.voicelen.cn"
KAM_ALIAS_2="webrtc.voicelen.cn"

# ===== MySQL(kamailio 必填,异机) =====
DB_HOST=""
DB_PORT="3306"
DB_USER=""
DB_PASS=""
DB_NAME=""

# ===== Redis(kamailio 必填,异机) =====
REDIS_HOST=""
REDIS_PORT="6379"
REDIS_PASS=""

# ===== rtpengine 必填 =====
RTPE_NG_PORT="2223"
RTPE_PORT_MIN="40000"
RTPE_PORT_MAX="60000"

# ===== caddy 必填 =====
CADDY_API_DOMAIN="api.voicelen.cn"
CADDY_API_UPSTREAM="localhost:18080"
CADDY_APP_DOMAIN="app.voicelen.cn"
CADDY_APP_UPSTREAM="localhost:13000"
CADDY_WEBRTC_DOMAIN="webrtc.voicelen.cn"
CADDY_WEBRTC_UPSTREAM="10.2.0.8:15062"   # 必须 = PRIVATE_IP:SIP_TCP_PORT(kamailio 只绑 PRIVATE_IP,不绑 loopback)

# ===== 可选 =====
KAMAILIO_BRANCH="58"
RTPENGINE_RELEASE="mr12.5.1"

# ===== freeswitch 可选(默认值通常够用) =====
# FS_BUILD_DIR="/usr/local/src"
# FS_VERSION="v1.10.12"
# FS_PREFIX="/usr/local/freeswitch"

# GitHub 代理:加速 freeswitch 源码下载(国内环境必填,直连 GitHub 极慢)
# 末尾必须带 / ;留空 = 直连。实测 gh-proxy.com 速度可达 6 MB/s,直连约 17 KB/s。
GH_PROXY="https://gh-proxy.com/"
